generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  resources Resource[]
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        ResourceType
  fileUrl     String
  createdAt   DateTime @default(now())

  uploadedBy  String
  user        User     @relation(fields: [uploadedBy], references: [id])
}

enum ResourceType {
  PDF
  LINK
}
