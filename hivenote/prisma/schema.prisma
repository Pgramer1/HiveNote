generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String      @id @default(cuid())
  name              String?
  email             String?     @unique
  emailVerified     DateTime?
  password          String?
  image             String?
  bio               String?     @db.Text
  createdAt         DateTime    @default(now())
  role              Role        @default(USER)
  isUniversityEmail Boolean     @default(false)
  university        String? // e.g., "Adani University", "IIT Delhi", etc.
  department        String? // Department code like "CSE", "ICT", etc.
  batch             String? // e.g., "28" for 2024-2028 batch

  resources    Resource[]
  favorites    Favorite[]
  comments     Comment[]
  commentLikes CommentLike[]

  accounts Account[]
  sessions Session[]
  votes    Vote[]
}

enum Role {
  USER
  ADMIN
}

model Resource {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        ResourceType
  fileUrl     String
  uploadedBy  String
  viewCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  university  String? // Which university this resource belongs to
  department  String? // Department code like "CSE", "ICT", etc.
  batch       String? // Which batch this resource is for (e.g., "28")
  semester    Int? // Which semester (1-8) this resource is for
  subjectId   String? // Which subject this resource is for

  user      User       @relation(fields: [uploadedBy], references: [id])
  subject   Subject?   @relation(fields: [subjectId], references: [id])
  votes     Vote[]
  favorites Favorite[]
  comments  Comment[]
}

enum ResourceType {
  PDF
  PPT
  LINK
}

model Subject {
  id           String   @id @default(cuid())
  name         String // e.g., "Data Structures", "Operating Systems"
  code         String // e.g., "CS201", "CS301"
  department   String? // DEPRECATED: Old department field (CSE, ICT, etc.)
  departmentId String? // New: Reference to DepartmentConfig
  batchId      String? // Which batch this subject belongs to
  semester     Int // Which semester (1-8) this subject is for
  university   String // Which university this subject belongs to
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  departmentConfig DepartmentConfig? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  batchConfig      BatchConfig?      @relation(fields: [batchId], references: [id], onDelete: SetNull)
  resources        Resource[]

  @@unique([code, university, semester, batchId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vote {
  id         String   @id @default(cuid())
  value      Int // +1 = upvote, -1 = downvote
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  userId     String
  resourceId String
  parentId   String? // For replies
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  parent   Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]     @relation("CommentReplies")
  likes    CommentLike[]
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// Admin-manageable entities
model DepartmentConfig {
  id          String   @id @default(cuid())
  code        String // e.g., "CSE", "ICT", "CIE"
  name        String // e.g., "Computer Science & Engineering"
  description String?
  university  String // Which university this department belongs to
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches  BatchConfig[]
  subjects Subject[]

  @@unique([code, university])
}

model BatchConfig {
  id           String           @id @default(cuid())
  code         String // e.g., "28" for 2024-2028
  years        String // e.g., "2024-2028"
  university   String
  departmentId String
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  department DepartmentConfig @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subjects   Subject[]

  @@unique([code, university, departmentId])
}
