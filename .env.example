# Database
# Neon PostgreSQL connection string (for production)
# Get from: https://neon.tech (create project and copy connection string)
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full
DATABASE_URL="postgresql://neondb_owner:password@your-project.region.aws.neon.tech/neondb?sslmode=verify-full"

# Local PostgreSQL (for development - optional)
# DATABASE_URL="postgresql://postgres:password@localhost:5432/hivenote?schema=public"

# NextAuth
# Base URL of your application
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# NextAuth Secret - Generate with: openssl rand -base64 32
# IMPORTANT: Use a strong random secret in production
# Generate: openssl rand -base64 32 (PowerShell: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256})))
NEXTAUTH_SECRET="your-secret-key-here"

# Email Service (Brevo / SendinBlue)
# Get your API key from: https://app.brevo.com/settings/keys/api
# Free tier: 300 emails/day - No domain verification needed!
BREVO_API_KEY="your-brevo-api-key-here"

# Email sender information
# Use your own email (no verification needed with Brevo)
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="HiveNote"

# Cloudinary (for file uploads)
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_API_TOKEN="your-api-token"